{
  "name": "hmd-whatsapp-service",
  "version": "1.0.0",
  "description": "WhatsApp notification service for HMD using Baileys",
  "main": "src/index.js",
  "bin": "src/index.js",
  "pkg": {
    "targets": ["node20-win-x64"],
    "outputPath": "../deployment/package/bin",
    "scripts": ["node_modules/thread-stream/**/*.js"],
    "assets": ["src/**/*"]
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "bundle": "esbuild src/index.js --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs --external:pino-pretty --external:pino/file"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.16",
    "express": "^4.21.2",
    "qrcode": "^1.5.4",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "p-queue": "^8.1.0",
    "dotenv": "^16.4.7",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "@yao-pkg/pkg": "^5.16.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "HMD Team",
  "license": "MIT"
}
