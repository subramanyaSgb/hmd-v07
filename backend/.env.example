# ============================================
# HMD System Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env with actual secrets to version control
# ============================================

# ============================================
# DATABASE CONFIGURATION (Required)
# ============================================
DATABASE_DRIVER=postgresql
DATABASE_USER=postgres
DATABASE_PASSWORD=<your-strong-database-password>
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=hmd

# ============================================
# SECURITY CONFIGURATION (Required)
# ============================================
# CRITICAL: Generate a secure SECRET_KEY for JWT token signing
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<generate-with-command-above-minimum-32-chars>

# JWT token expiration in minutes (default: 480 = 8 hours)
# For production, consider shorter expiration (e.g., 240 = 4 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Account lockout settings
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ============================================
# HTTPS CONFIGURATION (Production)
# ============================================
# Set to true in production to enforce HTTPS redirects
ENFORCE_HTTPS=false

# ============================================
# CSRF PROTECTION (Enabled by default)
# ============================================
CSRF_ENABLED=true

# ============================================
# RATE LIMITING (Enabled by default)
# ============================================
RATE_LIMIT_ENABLED=true

# ============================================
# CORS CONFIGURATION (Required for Production)
# ============================================
# Comma-separated list of allowed origins
# Development:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
# Production example:
# ALLOWED_ORIGINS=https://hmd.yourcompany.com,https://app.yourcompany.com

# ============================================
# REDIS CACHE CONFIGURATION (Optional)
# ============================================
# If Redis unavailable, falls back to in-memory cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=<your-redis-password-if-required>

# Set to false to disable caching entirely
CACHE_ENABLED=true

# ============================================
# OBSERVABILITY CONFIGURATION (Optional)
# ============================================
# OpenTelemetry distributed tracing
OTEL_ENABLED=false
OTEL_SERVICE_NAME=hmd-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ============================================
# SUVEECHI MYSQL — LIVE TORPEDO GPS SYNC (Optional)
# ============================================
# Pulls torpedo positions from SuVeechi vw_unit_status_ist
# and writes to fleet_live_locations every N seconds.
# Required only if SUVEECHI_SYNC_ENABLED=true
SUVEECHI_SYNC_ENABLED=false
SUVEECHI_HOST=10.10.156.157
SUVEECHI_PORT=3306
SUVEECHI_USER=view_user
SUVEECHI_PASSWORD=<MySQL view_user password>
SUVEECHI_DB=suvetracg
SUVEECHI_VIEW=vw_unit_status_ist
# Pull frequency in seconds (default 10)
SUVEECHI_SYNC_INTERVAL_SECONDS=10

# ============================================
# WBATNGL ORACLE — TORPEDO CAPACITY BACKFILL (Optional)
# ============================================
# Reads MAX(NET_WEIGHT) per LADLENO from WBATNGL weighbridge tables and
# updates FleetManagement.capacity nightly at 03:00 IST. Requires the
# Oracle Instant Client on the host (thick mode); see ORACLE_INSTANT_CLIENT_DIR.
# Required only if WBATNGL_SYNC_ENABLED=true
WBATNGL_SYNC_ENABLED=false
WBATNGL_HOST=10.10.1.67
WBATNGL_PORT=1522
WBATNGL_USER=ITROSYSP
WBATNGL_PASSWORD=<Oracle ITROSYSP password>
WBATNGL_SERVICE=WBATNGL
# Path to Oracle Instant Client (used by oracledb thick mode)
ORACLE_INSTANT_CLIENT_DIR=C:\oracle\instantclient_23_0

# WBATNGL trip mirror sync — pulls every WBATNGL trip-transaction row from
# BF3.WB_TRANS_DATA_ITRO + BF5.ZWB_TRANSACTION_DATA_ITRO_B into the local
# wbatngl_trip_mirror PG table every 60 s. Feeds /api/jsw/* endpoints (the
# JSW tab in Trip Management and the Plant Live page). Re-uses
# WBATNGL_HOST/PORT/USER/PASSWORD/SERVICE above. Independent kill-switch
# from WBATNGL_SYNC_ENABLED so capacity backfill and trip mirror can be
# toggled separately. See docs/plans/2026-05-08-wbatngl-trip-mirror-design.md.
WBATNGL_TRIP_SYNC_ENABLED=false
WBATNGL_TRIP_SYNC_INTERVAL_SECONDS=60

# ============================================
# HTS ORACLE — CONVERTER / HOT METAL DATA (Optional)
# ============================================
# Pulls HTS.VW_HTS_HOTMETAL_DATA from JSW's HTS Oracle, which exposes
# CONVERTER-SIDE data (HEAT_NO, CONVERTER_NO, HOTMETAL_QTY, TORPEDO_NO,
# TORPEDO_IN_TIME, TORPEDO_OUT_TIME, TORPEDO_QTY, CONVERTER_LIFE).
# This is the SMS-consumer-side view, complementary to WBATNGL's BF-
# producer-side weighbridge views.
#
# Connectivity established 11-May-2026 (DEP007 closed). Two gotchas we
# learned the hard way that day:
#
#  (1) Service name MUST be the fully-qualified JVMLPROD.JSW.IN, NOT the
#      bare JVMLPROD that Hari Prasad's 03-Apr email listed as "Database".
#      JSW's listener registers the service only under the FQDN; the bare
#      short name returns a misleading ORA-01034 ("ORACLE not available").
#      SID-based connection with SID=JVMLPROD also works as an alternative.
#
#  (2) User is ICT_IFACE (with underscore), password ICTIFACE (no
#      underscore) — NOT ITROSYSP. ITROSYSP is the WBATNGL user, separate
#      database, separate password. The two are unrelated.
#
# Requires the Oracle Instant Client on the host (thick mode); shares
# ORACLE_INSTANT_CLIENT_DIR with WBATNGL.
# Required only if HTS_SYNC_ENABLED=true
HTS_SYNC_ENABLED=false
HTS_HOST=10.10.70.227
HTS_PORT=1522
HTS_USER=ICT_IFACE
HTS_PASSWORD=<Oracle ICT_IFACE password>
HTS_SERVICE=JVMLPROD.JSW.IN
HTS_VIEW=HTS.VW_HTS_HOTMETAL_DATA
# Pull frequency in seconds (default 300 = 5 min; matches heat-cycle cadence)
HTS_SYNC_INTERVAL_SECONDS=300

# ============================================
# SYSTEM CONFIGURATION (Optional)
# ============================================
# Fallback torpedo capacity in MT when no active fleet
NOMINAL_CAPACITY=150.0

# Default travel time in minutes for unconfigured routes
DEFAULT_TRAVEL_TIME=30

# ============================================
# EMAIL / SMTP CONFIGURATION (Required for Email Features)
# ============================================
# SMTP server settings for sending emails (verification, MFA OTP, notifications)
# Supports Gmail, Outlook, Yahoo, and other SMTP providers
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email@gmail.com>
SMTP_PASSWORD=<your-app-password>
SMTP_FROM_EMAIL=noreply@hmd-system.com
SMTP_FROM_NAME=HMD System
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Frontend URL for email verification links
FRONTEND_URL=http://localhost:5173

# ============================================
# GOOGLE OAUTH CONFIGURATION (Optional)
# ============================================
# Create credentials at https://console.cloud.google.com/apis/credentials
# Required scopes: openid, email, profile
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/google/callback

# ============================================
# MFA CONFIGURATION (Required for TOTP MFA)
# ============================================
# Name shown in authenticator apps
MFA_ISSUER_NAME=HMD System

# Encryption key for storing TOTP secrets (32 bytes, base64 encoded)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MFA_SECRET_KEY=<generate-with-command-above>

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to production, ensure:
# [ ] DATABASE_PASSWORD is a strong, unique password
# [ ] SECRET_KEY is generated and kept secret
# [ ] ENFORCE_HTTPS=true
# [ ] ALLOWED_ORIGINS contains only your production domains
# [ ] REDIS_PASSWORD is set if using Redis
# [ ] OTEL_ENABLED=true if using distributed tracing
# [ ] Review ACCESS_TOKEN_EXPIRE_MINUTES (shorter = more secure)
# [ ] SMTP settings are configured for email features
# [ ] MFA_SECRET_KEY is generated and kept secret
# [ ] GOOGLE_REDIRECT_URI uses HTTPS in production
